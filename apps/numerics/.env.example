# Numerics (apps/numerics) environment.
#
# Copy to apps/numerics/.env — pydantic-settings auto-loads it (config.py).

# Massive market data (https://api.massive.com). Optional if the local parquet
# cache already covers the pairs/date-ranges you request; required to fetch new
# data.
MASSIVE_API_KEY=

# Parquet cache dir (relative paths resolve against apps/numerics/).
# Defaults to .cache/massive when unset.
MASSIVE_CACHE_DIR=.cache/massive
