# TS API (apps/api) environment.
#
# NOT auto-loaded by the app — export it before running, e.g.:
#   cd apps/api && set -a && source .env && set +a && pnpm dev
# In Docker/Coolify these are injected as container env vars instead.

# Postgres. Accepts postgres:// or postgresql:// (a +asyncpg suffix is stripped
# at runtime — it's a Python-only convention).
DATABASE_URL=postgresql://user:pass@localhost:5432/macrohero

# Clerk JWT verification — issuer + JWKS for your tenant.
CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json

# Comma-separated allowed CORS origins (the web app's origin).
CORS_ORIGINS=http://localhost:3000

# Port this API listens on. The web app's NEXT_PUBLIC_API_URL must point here.
PORT=8000

# DeepSeek (OpenAI-compatible) — required for the chat agent.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash

# Tavily web search — research subagent's search_current_events tool. Optional;
# leave empty to make search return a "not configured" envelope.
TAVILY_API_KEY=

# Numerics service base URL (projection tool). Defaults to http://localhost:8001
# when unset; docker-compose overrides it with the internal service name.
NUMERICS_URL=http://localhost:8001
