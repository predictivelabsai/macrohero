# Postgres connection. Accepts either bare postgres:// URL or postgresql+asyncpg://
# (the +asyncpg suffix is stripped at runtime since it's a Python-only convention).
DATABASE_URL=postgresql://user:pass@localhost:5432/macrohero

# Clerk JWT verification (same as the Python service uses).
CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json

# Comma-separated list of CORS origins.
CORS_ORIGINS=http://localhost:3000

# Port the TS API listens on. The Python api/ defaults to 8000; use 8002 locally
# so both can run side-by-side during the cutover window.
PORT=8002
