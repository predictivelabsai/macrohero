# Monorepo: web app under apps/web/, Python API still at api/.
# Pattern-based ignores below apply at any directory depth.

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# Env / secrets
.env
.env.local
.env.*.local
!.env.example

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / artifacts
coverage/
.nyc_output/
htmlcov/
.coverage
.coverage.*

# Local data
*.sqlite
*.db

# API cache (Massive market data, etc.)
api/.cache/

# Superpowers planning artifacts (specs/plans stay local)
docs/superpowers/
.superpowers/

# Playwright MCP cache / logs
.playwright-mcp/
