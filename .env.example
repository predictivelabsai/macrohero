# Top-level template. Copy the relevant subset to web/.env.local and api/.env.

# === Frontend (web/.env.local) ===

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/chat

# Backend URL the frontend talks to
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Backend (api/.env) ===

# User-supplied Postgres
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/macrohero

# Clerk JWT verification (issuer + JWKS) — copy from Clerk dashboard
CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_xxx

# CORS
CORS_ORIGINS=http://localhost:3000

# DeepSeek (OpenAI-compatible) for the /chat assistant
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Massive market data (https://api.massive.com)
MASSIVE_API_KEY=
MASSIVE_CACHE_DIR=.cache/massive

# Tavily web-search (https://tavily.com) — grounds the chat agent in current
# events. Free dev tier covers ~1k queries/mo. Empty disables the search tool.
TAVILY_API_KEY=
