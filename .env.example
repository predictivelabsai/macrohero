# Top-level template. Copy the relevant subset to apps/web/.env.local,
# apps/api/.env, and apps/numerics/.env.

# === Frontend (apps/web/.env.local) ===

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/chat

# TS api URL the frontend talks to
NEXT_PUBLIC_API_URL=http://localhost:8002

# === TS API (apps/api/.env) ===

# User-supplied Postgres
DATABASE_URL=postgresql://user:pass@host:5432/macrohero

# Clerk JWT verification (issuer + JWKS) — copy from Clerk dashboard
CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# DeepSeek (OpenAI-compatible) for the /chat assistant
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Tavily web-search (https://tavily.com) — grounds the research agent in
# current events. Free dev tier covers ~1k queries/mo.
TAVILY_API_KEY=

# Numerics service URL (internal HTTP endpoint for the projection tool)
NUMERICS_URL=http://localhost:8001

# Port the TS api listens on
PORT=8002

# === Numerics (apps/numerics/.env) ===

# Massive market data (https://api.massive.com) — historical factor prices
MASSIVE_API_KEY=
MASSIVE_CACHE_DIR=.cache/massive
