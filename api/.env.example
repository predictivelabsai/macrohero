# User-supplied Postgres (asyncpg driver)
DATABASE_URL=

# Clerk JWT verification — copy from Clerk dashboard ("API keys" / "JWT templates")
CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_xxx

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# DeepSeek (OpenAI-compatible) for the /chat assistant. The chat endpoint
# returns 503 if no key is set.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Massive market data (https://api.massive.com)
MASSIVE_API_KEY=
MASSIVE_CACHE_DIR=.cache/massive

# Tavily web-search (https://tavily.com) — grounds the chat agent in current
# events (e.g. user mentions "Hormuz war"). Free dev tier covers ~1k queries/mo.
# Leave empty to disable the search_current_events tool.
TAVILY_API_KEY=
